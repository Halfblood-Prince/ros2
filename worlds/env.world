<?xml version="1.0" ?>
<sdf version="1.6">
<world name="room">

  <include><uri>model://ground_plane</uri></include>
  <include><uri>model://sun</uri></include>

  <model name="wall">
    <static>true</static>
    <link name="link">
      <collision><geometry><box><size>8 8 1</size></box></geometry></collision>
      <visual><geometry><box><size>8 8 1</size></box></geometry></visual>
    </link>
    <pose>0 0 0 0 0 0</pose>
  </model>

</world>
</sdf>
